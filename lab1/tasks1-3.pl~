men:- man(X), write(X), nl, fail.

women:- woman(Y), write(Y), nl, fail.


% +X - unified
% -X - not unified
% ?X - ?

% children(+X)
% DESCRIPTION:
% writes all the X's children
children(X):- parent(X, Y), write(Y), nl, fail.


% mother(+X,-Y)
% DESCRIPTION:
% checks if X is Y's mother
mother(X,Y):- parent(X,Y), woman(X), true.


% mother(+X)
% DESCRIPTION:
% write the X's mother
mother(X):- mother(X, Y), write(Y).


% brother(+X,-Y)
% DESCRIPTION:
% checks if X is Y's brother
brother(X,Y):- man(X), X \== Y, man(Y), parent(Z, X), parent(Z, Y), true.


% brothers(+X)
% DESCRIPTION:
% write all the X's brothers
brothers(X):- brother(X,Y), write(Y), nl, fail.


% b_s(+X, -Y)
% DESCRIPTION:
% checks if X and Y are brothers or sisters
b_s(X, Y):- X \== Y, parent(Z, X), parent(Z, Y), true.


% b_s(+X)
% DESCRIPTION:
% writes all the X's brothers and sisters
b_s(X):- b_s(X,Y), write(Y), nl, fail.


% father(+X, -Y)
% DESCRIPTION:
% checks if X is Y's father
father(X, Y):- parent(X, Y), man(X), true.


% father(+X)
% DESCRIPTION:
% writes X's father
father(X):- father(X,Y), write(Y), !.


% wife(+X, -Y)
% DESCRIPTION:
% checks if X is Y's wife
wife(X, Y):- parent(X, Z), parent(Y, Z), woman(X), man(Y), true.


% wife(+X)
% DESCRIPTION:
% write X's wife
wife(X):- wife(X, Y), write(Y), !.


% grand_ma(+X, -Y)
% DESCRIPTION:
% checks if X is Y's grandmother
% using only facts
grand_ma(X, Y):- parent(Z, Y), parent(X, Z), woman(X), true.


% grand_ma_ver2(+X, +Y)
% DESCRIPTION:
% checks if X is Y's grandmother
% using predicates
grand_ma_ver2(X, Y):- mother(X, Z), mother(Z, Y), true.


% grand_mas(+X)
% DESCRIPTION:
% writes all X's grandmothers
grand_mas(X):- grand_ma(X, Y), write(Y), nl, fail.


% grand_pa_and_da(+X, +Y)
% DESCRIPTION:
% checks if X and Y are grandpa and granddaughter and vice versa
% using only facts
grand_pa_and_da(X, Y):- man(X), parent(X, Z), parent(Z, Y), woman(Y), true.
grand_pa_and_da(X,Y):-grand_pa_and_da(Y, X), true.


% grand_pa_and_da_ver2(+X, +Y)
% DESCRIPTION:
% checks if X and Y are grandpa and granddaughter and vice versa
% using other predicates
grand_pa_and_da_ver2(X, Y):- wife(Z, X), grand_ma(Z, Y), woman(Y), true.
grand_pa_and_da_ver2(X, Y):- woman(X), grand_ma(Z, X), wife(Z, Y), true.


%niece(+X, +Y)
niece(X, Y):- parent(Z, Y), parent(Z, W), W \== Y, daughter(X, W), true.

%niece_ver2(+X, +Y)
niece_ver2(X, Y):- b_s(Y, Z), daughter(X, Z), true.

%nieces(+X)
nieces(X):- parent(Z, X), woman(Z), parent(Z, Y), X \== Y, daughter(W, Y), write(W), nl, fail.
























